# ============================================================================
# Skill Agent - 环境变量示例
# 复制本文件为 .env 并填入实际值:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================================

# ----- LLM (必填) -----
# 任意兼容 OpenAI Chat Completions 协议的端点,例如:
#   OpenAI:    https://api.openai.com/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   硅基流动:    https://api.siliconflow.cn/v1
#   自建网关:    http://localhost:11434/v1  (Ollama)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 采样参数
TEMPERATURE=0.7
REQUEST_TIMEOUT_S=60

# ----- 路径(相对项目根) -----
SKILLS_PATH=skills
MEMORY_PATH=memory
VECTOR_PATH=vector_store

# ----- 运行参数 -----
MAX_ITERATIONS=10
SESSION_TTL_S=3600

# ----- 日志 -----
LOG_LEVEL=INFO          # DEBUG / INFO / WARNING / ERROR
LOG_TO_FILE=false
LOG_DIR=logs

# ----- Feature Flags -----
SKILL_DAG_ENABLED=false   # 启用 Skill → DAG 自动执行(实验性)
TOOL_CACHE_ENABLED=false  # 启用工具结果缓存(实验性)
