# ============================================================================
# Skill Agent - 环境变量示例
# 复制本文件为 .env 并填入实际值:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================================

# ----- LLM Provider 配置 -----
# 默认 Provider: openai / anthropic / local
DEFAULT_PROVIDER=openai

# ----- OpenAI Provider -----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ----- Anthropic (Claude) Provider -----
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- Local (Ollama) Provider -----
LOCAL_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3.2

# ----- 采样参数 -----
TEMPERATURE=0.7
REQUEST_TIMEOUT_S=60

# ----- 路径(相对项目根) -----
SKILLS_PATH=skills
MEMORY_PATH=memory
VECTOR_PATH=vector_store

# ----- 运行参数 -----
MAX_ITERATIONS=10
SESSION_TTL_S=3600

# ----- 日志 -----
LOG_LEVEL=INFO          # DEBUG / INFO / WARNING / ERROR
LOG_TO_FILE=false
LOG_DIR=logs

# ----- Feature Flags -----
SKILL_DAG_ENABLED=false        # 启用 Skill → DAG 自动执行(实验性)
TOOL_CACHE_ENABLED=false       # 启用工具结果缓存(实验性)
SELF_EVOLUTION_ENABLED=false   # 启用自我进化(实验性)
MULTI_PROVIDER_ENABLED=false   # 启用多 Provider 支持
SEMANTIC_MEMORY_ENABLED=false  # 启用语义记忆
SOUL_ENABLED=false            # 启用 Soul 身份系统

# ----- Embedding 配置 -----
EMBEDDING_PROVIDER=mock        # openai / local / mock
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ----- Soul 配置 -----
SOUL_PATH=soul/SOUL.md
SOUL_ENABLED=false

# ----- Heartbeat 配置 -----
HEARTBEAT_INTERVAL_SECONDS=1800
HEARTBEAT_PATH=heartbeat/HEARTBEAT.md

# ----- MCP 配置 -----
MCP_ENABLED=false
# MCP_SERVERS=[{"name": "github", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-github"]}]
