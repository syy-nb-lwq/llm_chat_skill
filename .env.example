# ===== LLM =====
# 必填:你的 LLM API Key(OpenAI 兼容协议)
LLM_API_KEY=sk-your-key-here

# LLM Base URL(OpenAI 兼容)
LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型
LLM_MODEL=gpt-4o-mini

# 采样温度 0~2
TEMPERATURE=0.7

# 单次 LLM 请求超时(秒)
REQUEST_TIMEOUT_S=60

# ===== 路径 =====
SKILLS_PATH=skills
MEMORY_PATH=memory
VECTOR_PATH=vector_store

# ===== 运行 =====
# Agent 最大迭代步数(防止死循环)
MAX_ITERATIONS=10

# WebSocket Session 过期时间(秒)
SESSION_TTL_S=3600

# ===== 日志 =====
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 是否同时输出到文件
LOG_TO_FILE=false

# 日志目录
LOG_DIR=logs

# ===== Feature Flags =====
# 是否启用新版技能 DAG 执行器(P2 阶段切换)
SKILL_DAG_ENABLED=true

# 是否启用工具结果缓存
TOOL_CACHE_ENABLED=false